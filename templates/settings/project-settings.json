{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Write(docs/*)",
      "Write(tasks/*)",
      "Write(qa/*)",
      "Write(.claude/commands/*)",
      "Write(.claude/skills/*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(rm -f:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(git push:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  },
  "env": {
    "K_ORCHESTRATOR_VERSION": "1.7.0",
    "TASKS_DIR": "tasks",
    "DOCS_DIR": "docs",
    "QA_DIR": "qa"
  }
}
